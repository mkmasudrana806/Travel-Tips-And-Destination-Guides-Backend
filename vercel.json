{
    "version": 2,
    "builds": [
        {
            "src": "src/server.ts",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "node_modules/swagger-ui-dist/**"
                ]
            }
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/server.ts"
        }
    ],
    "crons": [
        {
            "path": "/api/cron/media-cleanup",
            "schedule": "0 0 * * *"
        }
    ]
}